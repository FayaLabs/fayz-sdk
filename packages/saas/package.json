{
  "name": "@fayz-ai/saas",
  "version": "0.1.7",
  "description": "Fayz SDK SaaS layer — multi-tenancy, billing, permissions, org management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./org": {
      "source": "./src/org/index.ts",
      "types": "./dist/org/index.d.ts",
      "import": "./dist/org/index.js",
      "require": "./dist/org/index.cjs"
    },
    "./billing": {
      "source": "./src/billing/index.ts",
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js",
      "require": "./dist/billing/index.cjs"
    },
    "./permissions": {
      "source": "./src/permissions/index.ts",
      "types": "./dist/permissions/index.d.ts",
      "import": "./dist/permissions/index.js",
      "require": "./dist/permissions/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@fayz-ai/core": "workspace:^",
    "@fayz-ai/auth": "workspace:^",
    "@fayz-ai/ui": "workspace:^",
    "@supabase/supabase-js": "^2.45.0",
    "stripe": "^16.0.0",
    "zustand": "^4.5.0",
    "lucide-react": "^0.400.0",
    "@tanstack/react-table": "^8.20.0",
    "cmdk": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
