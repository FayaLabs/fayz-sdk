{
  "name": "@fayz/auth",
  "version": "0.1.0",
  "description": "Fayz SDK auth — pluggable authentication adapters with React hooks",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@fayz/core": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
