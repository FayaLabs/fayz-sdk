{
  "name": "@fayz-ai/portal",
  "version": "0.7.0",
  "description": "Fayz SDK member/learner portal scaffold — authenticated 'my courses' + player surface",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fayz-ai/core": "workspace:^",
    "@fayz-ai/auth": "workspace:^",
    "@fayz-ai/courses": "workspace:^",
    "zustand": "^4.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "keywords": [
    "fayz",
    "portal",
    "member",
    "courses",
    "lms"
  ],
  "private": true
}
