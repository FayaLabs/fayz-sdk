{
  "name": "@fayz-ai/app-runtime",
  "fayz": { "status": "internal" },
  "version": "0.6.0",
  "description": "Fayz SDK umbrella runtime — single-pin re-export of core, auth, saas, ui, shop, storefront for generated apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist && cp ../ui/src/styles.css dist/styles.css && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "check:publish-safety": "node ../../scripts/check-public-package-safety.mjs packages/app-runtime",
    "prepublishOnly": "pnpm run check:publish-safety",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@fayz-ai/core": "workspace:^",
    "@fayz-ai/auth": "workspace:^",
    "@fayz-ai/saas": "workspace:^",
    "@fayz-ai/ui": "workspace:^",
    "@fayz-ai/shop": "workspace:^",
    "@fayz-ai/storefront": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "keywords": [
    "fayz",
    "fayz-sdk",
    "runtime",
    "umbrella"
  ],
  "private": true
}
