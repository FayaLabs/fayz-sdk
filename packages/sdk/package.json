{
  "name": "@fayz-ai/sdk",
  "version": "0.1.5",
  "description": "Fayz SDK — API client, app params, runtime broker helpers, and shared types for generated Fayz projects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./app-params": {
      "source": "./src/app-params.ts",
      "types": "./dist/app-params.d.ts",
      "import": "./dist/app-params.js",
      "require": "./dist/app-params.cjs"
    },
    "./client": {
      "source": "./src/client.ts",
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./shop": {
      "source": "./src/shop.ts",
      "types": "./dist/shop.d.ts",
      "import": "./dist/shop.js",
      "require": "./dist/shop.cjs"
    },
    "./release-channels": {
      "source": "./src/release-channels.ts",
      "types": "./dist/release-channels.d.ts",
      "import": "./dist/release-channels.js",
      "require": "./dist/release-channels.cjs"
    },
    "./release-channels.json": "./src/release-channels.json",
    "./supported-surface": {
      "source": "./src/supported-surface.ts",
      "types": "./dist/supported-surface.d.ts",
      "import": "./dist/supported-surface.js",
      "require": "./dist/supported-surface.cjs"
    },
    "./supported-surface.json": "./src/supported-surface.json",
    "./ai-builder": {
      "source": "./src/ai-builder.ts",
      "types": "./dist/ai-builder.d.ts",
      "import": "./dist/ai-builder.js",
      "require": "./dist/ai-builder.cjs"
    },
    "./runtime": {
      "source": "./src/runtime.ts",
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./types": {
      "source": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "license": "MIT",
  "homepage": "https://github.com/FayaLabs/fayz-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FayaLabs/fayz-sdk.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/FayaLabs/fayz-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fayz",
    "fayz-sdk",
    "runtime",
    "api-client"
  ]
}
