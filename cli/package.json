{
  "name": "@fayz-ai/cli",
  "fayz": {
    "status": "beta"
  },
  "version": "0.8.0",
  "description": "Fayz CLI — scaffold, validate, extract and upgrade repo-per-app projects",
  "type": "module",
  "bin": {
    "fayz": "./dist/index.js"
  },
  "files": [
    "dist",
    "pools.config.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsup && node --test \"test/**/*.test.mjs\"",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "fayz",
    "fayz-sdk",
    "cli",
    "scaffold"
  ]
}
