{
  "name": "@fayz-ai/plugin-blog",
  "version": "0.1.0",
  "description": "[experimental] Fayz SDK — blog / articles plugin (website surface)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.0.0 || ^7.0.0"
  },
  "dependencies": {
    "@fayz-ai/core": "workspace:^",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.30.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "@types/react-dom": "^18.3.0"
  },
  "license": "MIT",
  "keywords": [
    "fayz",
    "fayz-plugin",
    "fayz-sdk"
  ]
}
