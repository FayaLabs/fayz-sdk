{
  "name": "@fayz-ai/plugin-agenda",
  "fayz": { "status": "beta" },
  "version": "0.1.8",
  "description": "Fayz SDK — plugin-agenda plugin",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@fayz-ai/core": "workspace:^",
    "@fayz-ai/ui": "workspace:^",
    "lucide-react": "^0.400.0",
    "zustand": "^4.5.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fayz-ai/saas": "workspace:^",
    "@fayz-ai/plugin-financial": "workspace:^",
    "@tanstack/react-table": "^8.20.0",
    "@fullcalendar/resource-timegrid": "^6.1.0",
    "@fullcalendar/list": "^6.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "@types/react-dom": "^18.3.0",
    "vitest": "^2.1.9",
    "react-dom": "^18.3.0"
  },
  "license": "MIT",
  "keywords": [
    "fayz",
    "fayz-plugin",
    "fayz-sdk"
  ],
  "publishConfig": {
    "access": "public"
  }
}
